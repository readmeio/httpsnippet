{
  "name": "@readme/httpsnippet",
  "version": "11.1.0",
  "description": "HTTP Request snippet generator for *most* languages",
  "keywords": [
    "api",
    "clojure",
    "crystal",
    "csharp",
    "curl",
    "go",
    "har",
    "http",
    "httpie",
    "httr",
    "java",
    "javascript",
    "jquery",
    "kotlin",
    "objc",
    "objective-c",
    "ocaml",
    "php",
    "python",
    "requests",
    "ruby",
    "rust",
    "shell",
    "snippet",
    "swift",
    "xhr",
    "xmlhttprequest"
  ],
  "homepage": "https://github.com/readmeio/httpsnippet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/readmeio/httpsnippet.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./helpers/code-builder": {
      "require": "./dist/helpers/code-builder.cjs",
      "import": "./dist/helpers/code-builder.mjs"
    },
    "./helpers/reducer": {
      "require": "./dist/helpers/reducer.cjs",
      "import": "./dist/helpers/reducer.mjs"
    },
    "./targets": {
      "require": "./dist/targets/index.cjs",
      "import": "./dist/targets/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "attw": "attw --pack --format table-flipped",
    "build": "tsdown",
    "clean": "rm -rf dist/",
    "format": "npx oxlint --fix && npx oxfmt --write",
    "lint": "npx oxlint && npx oxfmt --check && tsc",
    "prebuild": "npm run clean",
    "prepack": "npm run build",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "dotenv": "^8.2.0",
    "node-fetch": "^3.3.2",
    "qs": "^6.15.0",
    "stringify-object": "^3.3.0",
    "type-fest": "^5.5.0"
  },
  "devDependencies": {
    "@readme/oxlint-config": "^1.1.2",
    "@types/har-format": "^1.2.15",
    "@types/node": "^25.5.0",
    "@types/qs": "^6.15.0",
    "@types/stringify-object": "^4.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.62.0",
    "require-directory": "^2.1.1",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  }
}
